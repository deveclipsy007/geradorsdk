# Configurações do Servidor
HOST=0.0.0.0
PORT=8001
DEBUG=false
ENVIRONMENT=development

# Configurações do Banco de Dados
DATABASE_URL=sqlite:///./agents.db
DATABASE_ECHO=false

# Chaves de API dos Modelos de IA
# Configure pelo menos uma das chaves abaixo para usar os respectivos modelos

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI GPT
OPENAI_API_KEY=sk-proj-xxxxx

# Groq (Llama, Mixtral)
GROQ_API_KEY=gsk_xxxxx

# Configurações de Segurança
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=*

# Configurações de Upload e Cache
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
CACHE_TTL=3600

# Configurações de Log
LOG_LEVEL=INFO
LOG_FILE=app.log

# Integração OCM Drizzy (Opcional)
DRIZZY_ENABLED=true
DRIZZY_WEBHOOK_URL=https://your-drizzy-webhook-url
DRIZZY_API_KEY=your-drizzy-api-key

# Configurações de Chat
CHAT_SESSION_TIMEOUT=7200
MAX_CHAT_HISTORY=100

# Configurações da Evolution API v2.2.3
EVOLUTION_API_URL=https://evolution.agentecortex.com
EVOLUTION_API_KEY=your_evolution_api_key_if_any
EVOLUTION_GLOBAL_API_KEY=your_global_api_key_if_different

# ==========================================
# CONFIGURAÇÃO CENTRALIZADA DE PORTAS
# ==========================================
# Frontend: Porta 8005 (única autorizada)
# Backend:  Porta 8001 (API apenas)

BACKEND_HOST=localhost
BACKEND_PORT=8001
