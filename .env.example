# Configurações do Servidor
# Endereço onde o servidor irá escutar
HOST=0.0.0.0
# Porta utilizada pelo servidor
=======
# Porta padrão do backend
PORT=8000
# Ativa o modo de depuração
DEBUG=false
# Nome do ambiente de execução
ENVIRONMENT=development

# Configurações do Banco de Dados
# URL de conexão com o banco de dados
DATABASE_URL=sqlite:///./agents.db
# Exibe comandos SQL no log
DATABASE_ECHO=false

# Chaves de API dos Modelos de IA
# Configure pelo menos uma das chaves abaixo para usar os respectivos modelos

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI API key
OPENAI_API_KEY=sk-proj-xxxxx

# Groq API key
GROQ_API_KEY=gsk_xxxxx

# Configurações de Segurança
# Chave secreta da aplicação
SECRET_KEY=your-secret-key-change-in-production

# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=*
=======
# Lista de origens permitidas (separadas por vírgula)
CORS_ORIGINS=https://seu-dominio.com,https://app.seu-dominio.com

# Configurações de Upload e Cache
# Diretório para uploads de arquivos
UPLOAD_DIR=./uploads
# Tamanho máximo de upload em bytes
MAX_UPLOAD_SIZE=10485760
# Tempo de vida do cache em segundos
CACHE_TTL=3600

# Limite de Requisições
RATE_LIMIT=100/minute

# Configurações de Log
# Nível de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
# Arquivo de saída dos logs
LOG_FILE=app.log

# Integração OCM Drizzy (Opcional)
# Habilita integração com OCM Drizzy
DRIZZY_ENABLED=true
# URL do webhook do Drizzy
DRIZZY_WEBHOOK_URL=https://your-drizzy-webhook-url
# Chave de API do Drizzy
DRIZZY_API_KEY=your-drizzy-api-key

# Integrações Empresariais
# URL base para Evolution API (WhatsApp)
EVOLUTION_API_URL=https://api.evolution.com
# Chave de API da Evolution
EVOLUTION_API_KEY=your-evolution-key

# Caminho para credenciais do Google Calendar (arquivo JSON)
GOOGLE_CALENDAR_CREDENTIALS=path/to/credentials.json

# Chave de API do SendGrid (opcional)
SENDGRID_API_KEY=your-sendgrid-key

# Servidor SMTP para envio de e-mails
SMTP_SERVER=smtp.gmail.com
# Porta do servidor SMTP
SMTP_PORT=587
# Usuário de autenticação SMTP
SMTP_USERNAME=your-email@gmail.com
# Senha ou token SMTP
SMTP_PASSWORD=your-app-password
# Habilita TLS na conexão SMTP
SMTP_USE_TLS=true

# Chave secreta do Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
# Segredo do webhook do Stripe (opcional)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Chave de API do Asaas
ASAAS_API_KEY=your-asaas-key
# Usa ambiente sandbox do Asaas (true/false)
ASAAS_SANDBOX=true

# Configurações de Chat
# Tempo de expiração da sessão de chat em segundos
CHAT_SESSION_TIMEOUT=7200
# Número máximo de mensagens no histórico do chat
=======
MAX_CHAT_HISTORY=100
