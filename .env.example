# Configurações do Servidor
HOST=0.0.0.0
# Porta padrão do backend
PORT=8000
DEBUG=false
ENVIRONMENT=development

# Configurações do Banco de Dados
DATABASE_URL=sqlite:///./agents.db
DATABASE_ECHO=false

# Chaves de API dos Modelos de IA
# Configure pelo menos uma das chaves abaixo para usar os respectivos modelos

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI GPT
OPENAI_API_KEY=sk-proj-xxxxx

# Groq (Llama, Mixtral)
GROQ_API_KEY=gsk_xxxxx

# Configurações de Segurança
SECRET_KEY=your-secret-key-change-in-production
# Lista de origens permitidas (separadas por vírgula)
CORS_ORIGINS=https://seu-dominio.com,https://app.seu-dominio.com

# Configurações de Upload e Cache
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
CACHE_TTL=3600

# Configurações de Log
LOG_LEVEL=INFO
LOG_FILE=app.log

# Integração OCM Drizzy (Opcional)
DRIZZY_ENABLED=true
DRIZZY_WEBHOOK_URL=https://your-drizzy-webhook-url
DRIZZY_API_KEY=your-drizzy-api-key

# Configurações de Chat
CHAT_SESSION_TIMEOUT=7200
MAX_CHAT_HISTORY=100
